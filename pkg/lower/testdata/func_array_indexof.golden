func Find(n float64) float64 {
	var xs *value.Array[float64] = value.NewArray[float64](10, 20, 30, 40)
	var at float64 = xs.IndexOf(n, func(a, b float64) bool {
		return a == b
	})
	var score float64 = at
	if xs.Includes(n, func(a, b float64) bool {
		return a == b || a != a && b != b
	}) {
		score += 1000
	}
	var words *value.Array[value.BStr] = value.NewArray[value.BStr](value.FromGoString("a"), value.FromGoString("bb"), value.FromGoString("ccc"))
	score += words.IndexOf(value.FromGoString("bb"), func(a, b value.BStr) bool {
		return a.Equal(b)
	})
	return score
}
