package main

import (
	"github.com/tamnd/bento/pkg/value"
)

func Area(w float64, h float64) float64 {
	return w * h
}
func main() {
	var sum float64 = 0
	{
		var i float64 = 1
		for ; i <= 3; i++ {
			sum = sum + Area(i, i)
		}
	}
	value.ConsoleLog(value.FromGoString("total area"), value.NumberToString(sum))
}
