package main

import (
	"github.com/tamnd/bento/pkg/value"
)

func main() {
	var dir value.BStr = value.Mkdtemp(value.PathJoin(value.Tmpdir(), value.FromGoString("bento-bench-")))
	var count float64 = 200
	var payload value.BStr = value.FromGoString("x").Repeat(512)
	var bytes float64 = 0
	for pass := 0.0; pass < 3; pass++ {
		for i := 0.0; i < count; i++ {
			value.WriteFileSync(value.PathJoin(dir, value.FromGoString("f").ConcatN(value.NumberToString(i), value.FromGoString(".txt"))), payload)
		}
		for i := 0.0; i < count; i++ {
			bytes += value.ReadFileSyncUTF8(value.PathJoin(dir, value.FromGoString("f").ConcatN(value.NumberToString(i), value.FromGoString(".txt")))).Length()
		}
	}
	value.RmSync(dir, true, true)
	value.ConsoleLog(value.NumberToString(bytes))
}
