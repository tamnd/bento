func LabelWidth(n float64) float64 {
	var xs *value.Array[float64] = value.NewArray[float64](1, 2, 3)
	var ys *value.Array[value.BStr] = value.MapArray[float64, value.BStr](xs, func(x float64) value.BStr {
		return value.NumberToString((x * n))
	})
	var total float64 = 0
	for _, y := range ys.Elems() {
		total += y.Length()
	}
	return total
}
