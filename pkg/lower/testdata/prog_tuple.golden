package main

import (
	"github.com/tamnd/bento/pkg/value"
)

type Tuple_num_num struct {
	E0 float64
	E1 float64
}
type Tuple_str_num struct {
	E0 value.BStr
	E1 float64
}

func Minmax(xs *value.Array[float64]) Tuple_num_num {
	lo := xs.At(0)
	hi := xs.At(0)
	for _, x := range xs.Elems() {
		if x < lo {
			lo = x
		}
		if x > hi {
			hi = x
		}
	}
	return Tuple_num_num{E0: lo, E1: hi}
}
func main() {
	pair := Tuple_str_num{E0: value.FromGoString("age"), E1: 42}
	value.ConsoleLog(pair.E0)
	value.ConsoleLog(value.NumberToString(pair.E1))
	label := pair.E0
	value_ := pair.E1
	value.ConsoleLog(label)
	value.ConsoleLog(value.NumberToString(value_))
	_bt0 := Minmax(value.NewArray[float64](3, 1, 4, 1, 5, 9, 2, 6))
	lo := _bt0.E0
	hi := _bt0.E1
	value.ConsoleLog(value.NumberToString(lo))
	value.ConsoleLog(value.NumberToString(hi))
}
