func Lengths(n float64) float64 {
	xs := value.NewArray[float64](n, n+1, n+2)
	dashed := xs.Join(value.FromGoString("-"), func(x float64) value.BStr {
		return value.NumberToString(x)
	})
	defaulted := xs.Join(value.FromGoString(","), func(x float64) value.BStr {
		return value.NumberToString(x)
	})
	words := value.NewArray[value.BStr](value.FromGoString("a"), value.FromGoString("bb"), value.FromGoString("ccc"))
	joinedWords := words.Join(value.FromGoString(", "), func(x value.BStr) value.BStr {
		return x
	})
	return dashed.Length() + defaulted.Length() + joinedWords.Length()
}
